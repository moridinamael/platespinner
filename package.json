{
  "name": "platespinner",
  "version": "1.0.0",
  "description": "AI-powered kanban board that uses CLI tools (Claude Code, Codex, Gemini) to generate, plan, and execute development tasks",
  "author": "Matt Freeman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moridinamael/platespinner.git"
  },
  "homepage": "https://github.com/moridinamael/platespinner#readme",
  "bugs": {
    "url": "https://github.com/moridinamael/platespinner/issues"
  },
  "keywords": [
    "kanban",
    "ai",
    "claude-code",
    "task-management",
    "developer-tools",
    "codex",
    "gemini",
    "drag-and-drop",
    "websocket",
    "react"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && node server/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "ansi-to-html": "0.7.2",
    "express": "^4.21.0",
    "marked": "^15.0.12",
    "nodemailer": "^6.9.0",
    "recharts": "^3.8.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "supertest": "^7.2.2",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
