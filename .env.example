# Bind address (default: 127.0.0.1, use 0.0.0.0 for all interfaces)
# HOST=127.0.0.1

# Server port (default: 3001)
# PORT=3001

# API token for mutating requests (required when HOST is not localhost)
# Generate one with: node -e "console.log(crypto.randomUUID())"
# APP_API_TOKEN=

# Railway CLI binary path (default: 'railway' from PATH)
# RAILWAY_BIN=railway

# Enable debug logging for autoclicker judgment agent (default: off)
# DEBUG_AUTOCLICKER=1

# Allow insecure TLS for the /api/proxy endpoint (default: off)
# Only enable for development/debugging. Disables certificate validation.
# PROXY_ALLOW_INSECURE_TLS=1
